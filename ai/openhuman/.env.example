# ─── OpenHuman Core — Local deployment overlay ────────────────────────────────
# Minimal variables needed to run openhuman-core locally via Docker Compose.
# For the full variable reference, see the upstream .env.example:
#   https://github.com/tinyhumansai/openhuman/blob/main/.env.example

# ─── Build ────────────────────────────────────────────────────────────────────
# Path to your local clone of the openhuman repo.
# The Docker image is built from this directory on first start.
# Clone: git clone https://github.com/tinyhumansai/openhuman.git ~/repos/openhuman
OPENHUMAN_REPO_PATH=~/repos/openhuman

# ─── Authentication ───────────────────────────────────────────────────────────
# RPC bearer token — required for any client calling /rpc on this instance.
# Auto-generated by start.sh on first run. Do not change after first use.
# See: docs/env-conventions.md
OPENHUMAN_CORE_TOKEN=GENERATE_ME

# ─── Network ──────────────────────────────────────────────────────────────────
# Port the core listens on (host side). Default: 7788.
# OPENHUMAN_CORE_PORT=7788

# ─── Resource limits ─────────────────────────────────────────────────────────
# Maximum memory the container may use.
# OPENHUMAN_CORE_MEM_LIMIT=4g

# Maximum CPU cores the container may use.
# OPENHUMAN_CORE_CPUS=2.0

# ─── Logging ─────────────────────────────────────────────────────────────────
# Rust log level: error | warn | info | debug | trace
# RUST_LOG=info
